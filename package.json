{
  "name": "vitest-forall",
  "version": "0.1.0",
  "description": "Vitest 上で ∀検証（Z3形式検証）を ∃検証（fast-check）と同じテストレイヤーに統合するライブラリ",
  "type": "module",
  "license": "MIT",
  "author": "Sasaki Motoaki",
  "homepage": "https://github.com/msasaki666/vitest-forall#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msasaki666/vitest-forall.git"
  },
  "bugs": {
    "url": "https://github.com/msasaki666/vitest-forall/issues"
  },
  "keywords": [
    "vitest",
    "z3",
    "smt",
    "formal-verification",
    "property-testing"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run test",
    "prepare": "lefthook install",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run verify"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "fast-check": "^4.8.0",
    "z3-solver": "^4.16.0"
  },
  "peerDependencies": {
    "vitest": "^4.1.9"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "lefthook": "^2.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
